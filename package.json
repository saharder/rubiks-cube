{
  "name": "@samharder/rubiks-cube",
  "version": "0.1.0",
  "type": "module",
  "description": "Rubik's Cube rendered with Three.js",
  "homepage": "https://github.com/saharder/rubiks-cube",
  "author":"Sam Harder",
  "license": "GPL-3.0-only",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:pages": "vite build --config vite.config.pages.ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "three": ">=0.150.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/three": "latest",
    "three": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vite-plugin-dts": "latest"
  }
}
